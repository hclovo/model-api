# ===== Cloudflare AI Gateway =====
# Token: Cloudflare Dashboard → AI Gateway → 你的 Gateway → API Tokens
CF_AIG_TOKEN=your_cf_aig_token_here

# 完整的 /compat 端点（账号 ID + Gateway 名称）
# 格式: https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_name}/compat
CF_AIG_BASE_URL=https://gateway.ai.cloudflare.com/v1/your_account_id/your_gateway_name/compat

# ===== Server =====
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ===== Auth =====
# 可选：设置后客户端需携带 "Authorization: Bearer <key>"
API_SECRET_KEY=
