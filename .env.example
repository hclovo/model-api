# ===== API Keys =====
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ===== Cloudflare Proxy =====
# Cloudflare Worker URL for proxying requests to geo-restricted APIs
# Example: https://your-worker.your-subdomain.workers.dev
CLOUDFLARE_PROXY_URL=

# ===== Server =====
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ===== Auth =====
# Optional: set a secret key to protect your API
API_SECRET_KEY=